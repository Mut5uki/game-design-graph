{
  "name": "game-design-graph",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "start": "vite --host --open",
    "collab:server": "npm run start --prefix server",
    "collab:server:dev": "npm run dev --prefix server",
    "collab:signaling": "y-webrtc-signaling",
    "collab:install": "npm install --prefix server",
    "setup": "npm install && npm run collab:install",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "build:pages": "tsc -p tsconfig.app.json --noEmit && vite build && node scripts/pages-postbuild.mjs",
    "sync:public-projects": "node scripts/sync-public-projects.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hocuspocus/provider": "^4.2.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@xyflow/react": "^12.6.4",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "dexie": "^4.0.11",
    "html-to-image": "^1.11.11",
    "immer": "^10.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.2",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.31",
    "zod": "^3.25.67",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.10",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.1.10",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
