@echo off
REM Copy to frpc.local.cmd and paste your token:tunnelId from Sakura panel
REM Tunnel local port must be 3888 (see docs\COLLAB_SAKURAFRP.md)

cd /d "%~dp0"

if not exist "frpc_windows_amd64.exe" (
  echo [INFO] Download frpc from Sakura panel into deploy\sakurafrp\
  pause
  exit /b 1
)

echo Starting Sakura FRP (local port 3888)...
frpc_windows_amd64.exe -f PASTE_TOKEN_AND_TUNNEL_ID_HERE

pause
