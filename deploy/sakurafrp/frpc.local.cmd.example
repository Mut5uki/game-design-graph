@echo off
chcp 65001 >nul
REM 复制本文件为 frpc.local.cmd（勿提交 git），填入樱花面板「批量操作 → 配置文件」里的启动参数
REM 示例：frpc_windows_amd64.exe -f 你的访问密钥:网页隧道ID,协作隧道ID
REM 请把 frpc 放在本目录，或写完整路径

cd /d "%~dp0"

if not exist "frpc_windows_amd64.exe" (
  echo [提示] 请从 SakuraFrp 面板「软件下载」下载 frpc，放到 deploy\sakurafrp\
  echo 或在下方命令里写 frpc 的完整路径
  pause
  exit /b 1
)

echo 启动樱花 FRP（网页 3888 + 协作 1234）...
frpc_windows_amd64.exe -f 在此填入访问密钥:隧道ID1,隧道ID2

pause
