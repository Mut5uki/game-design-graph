# 华为云 / 无域名：仅用公网 IP 访问（HTTP + WS）
# 1. 复制到服务器：/etc/nginx/conf.d/game-design-graph.conf
# 2. 将 YOUR_PUBLIC_IP 改为实际 IP（server_name 填 IP 或 _）
# 3. nginx -t && systemctl reload nginx

upstream gdg_collab {
    server 127.0.0.1:1234;
    keepalive 64;
}

server {
    listen 80;
    server_name 120.46.79.53 _;

    root /var/www/game-design-graph;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /collab {
        rewrite ^/collab$ / break;
        proxy_pass http://gdg_collab;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    gzip on;
    gzip_types text/css application/javascript application/json;
}
